{
  "name": "ergo-router",
  "version": "0.1.0",
  "description": "REST-compliant router for ergo with strict Fast Fail semantics",
  "main": "index.js",
  "type": "module",
  "exports": {
    ".": "./index.js",
    "./lib/transport": "./lib/transport/index.js",
    "./lib/*": "./lib/*.js"
  },
  "files": [
    "index.js",
    "lib/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "lint": "eslint .",
    "format": "prettier --write \"**/*.js\"",
    "format:check": "prettier --check \"**/*.js\"",
    "pretest": "npm run lint && npm run format:check",
    "test": "c8 node --test \"**/*.spec.unit.js\" \"**/*.spec.func.js\"",
    "test:watch": "node --test --watch \"**/*.spec.unit.js\" \"**/*.spec.func.js\"",
    "preversion": "npm test",
    "prepublishOnly": "npm test",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "ergo",
    "router",
    "rest",
    "api",
    "fast-fail"
  ],
  "author": "Jason Cust <jason@centralping.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CentralPing/ergo-router"
  },
  "bugs": {
    "url": "https://github.com/CentralPing/ergo-router/issues"
  },
  "homepage": "https://github.com/CentralPing/ergo-router",
  "dependencies": {
    "find-my-way": "^9.0.0"
  },
  "peerDependencies": {
    "ergo": ">=0.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "c8": "^11.0.0",
    "ergo": "file:../ergo",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "simple-git-hooks": "^2.12.1",
    "undici": "^7.24.2"
  },
  "c8": {
    "include": [
      "lib/**/*.js",
      "index.js"
    ],
    "exclude": [
      "**/*.spec.*.js",
      "**/node_modules/**",
      "**/coverage/**"
    ],
    "branches": 80,
    "functions": 100,
    "lines": 80,
    "statements": 80,
    "reporter": [
      "text",
      "lcov"
    ],
    "all": true
  }
}
