{
  "name": "@centralping/ergo-router",
  "version": "0.4.1",
  "description": "REST-compliant router for @centralping/ergo with strict Fast Fail semantics",
  "main": "index.js",
  "type": "module",
  "types": "types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./index.js"
    },
    "./lib/transport": {
      "types": "./types/lib/transport/index.d.ts",
      "default": "./lib/transport/index.js"
    },
    "./openapi": {
      "types": "./types/openapi.d.ts",
      "default": "./openapi.js"
    },
    "./lib/*": {
      "types": "./types/lib/*.d.ts",
      "default": "./lib/*.js"
    }
  },
  "files": [
    "index.js",
    "openapi.js",
    "lib/",
    "types/",
    "!**/*.spec.*.js",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "lint": "eslint .",
    "format": "prettier --write \"**/*.js\"",
    "format:check": "prettier --check \"**/*.js\"",
    "pretest": "npm run lint && npm run format:check",
    "test": "c8 node --test --test-force-exit \"**/*.spec.unit.js\" \"**/*.spec.func.js\"",
    "test:watch": "node --test --watch \"**/*.spec.unit.js\" \"**/*.spec.func.js\"",
    "preversion": "npm test",
    "types": "tsc && cp -r types-override/. types/",
    "check-types": "npm run types && tsc --project tsconfig.check-types.json",
    "prepublishOnly": "npm test && npm run check-types",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "ergo",
    "router",
    "rest",
    "api",
    "fast-fail"
  ],
  "author": "Jason Cust <jason@centralping.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CentralPing/ergo-router.git"
  },
  "bugs": {
    "url": "https://github.com/CentralPing/ergo-router/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://centralping.github.io/packages/ergo-router/",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/jasoncust"
  },
  "dependencies": {
    "find-my-way": "^9.0.0"
  },
  "peerDependencies": {
    "@centralping/ergo": ">=0.5.0 <0.6.0",
    "@types/node": ">= 22"
  },
  "peerDependenciesMeta": {
    "@types/node": {
      "optional": true
    }
  },
  "devDependencies": {
    "@centralping/ergo": "file:../ergo",
    "@eslint/js": "^10.0.1",
    "@seriousme/openapi-schema-validator": "^2.9.0",
    "@types/node": "^25.9.1",
    "c8": "^11.0.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "lint-staged": "^17.0.2",
    "prettier": "^3.8.1",
    "simple-git-hooks": "^2.12.1",
    "typescript": "^6.0.3",
    "undici": "^8.2.0"
  },
  "c8": {
    "include": [
      "lib/**/*.js",
      "index.js"
    ],
    "exclude": [
      "**/*.spec.*.js",
      "**/node_modules/**",
      "**/coverage/**"
    ],
    "branches": 80,
    "functions": 100,
    "lines": 80,
    "statements": 80,
    "reporter": [
      "text",
      "lcov"
    ],
    "all": true
  }
}
